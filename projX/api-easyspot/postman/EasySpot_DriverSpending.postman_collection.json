{
  "info": {
    "name": "EasySpot - Driver Spending",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "driver_token", "value": "" },
    { "key": "manager_token", "value": "" },
    { "key": "vehicle_id", "value": "" },
    { "key": "vehicle_id_2", "value": "" }
  ],
  "item": [
    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Get Driver JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Driver JWT obtained', function() {",
                  "  pm.response.to.have.status(200);",
                  "  const token = pm.response.json().access_token;",
                  "  pm.expect(token).to.be.a('string');",
                  "  pm.collectionVariables.set('driver_token', token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/test/token?role=DRIVER"
          }
        },
        {
          "name": "Get Manager JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Manager JWT obtained', function() {",
                  "  pm.response.to.have.status(200);",
                  "  const token = pm.response.json().access_token;",
                  "  pm.expect(token).to.be.a('string');",
                  "  pm.collectionVariables.set('manager_token', token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/test/token?role=MANAGER"
          }
        },
        {
          "name": "Seed Test Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Seed data returned', function() {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.vehicleId).to.be.a('string');",
                  "  pm.expect(body.secondaryVehicleId).to.be.a('string');",
                  "  pm.collectionVariables.set('vehicle_id', body.vehicleId);",
                  "  pm.collectionVariables.set('vehicle_id_2', body.secondaryVehicleId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/test/seed",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }]
          }
        }
      ]
    },
    {
      "name": "1. GET spending - success (30D)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
        "pm.test('Response shape is correct', function() {",
        "  const body = pm.response.json();",
        "  pm.expect(body.totals.totalSpent).to.be.a('number');",
        "  pm.expect(body.totals.avgPerSession).to.be.a('number');",
        "  pm.expect(body.totals.parkingSpent).to.be.a('number');",
        "  pm.expect(body.totals.chargingSpent).to.be.a('number');",
        "  pm.expect(body.insights).to.be.an('object');",
        "  pm.expect(body.timeseries).to.be.an('array');",
        "  pm.expect(body.breakdownByPark).to.be.an('array');",
        "  pm.expect(body.breakdownByVehicle).to.be.an('array');",
        "  pm.expect(body.history).to.be.an('array');",
        "});"
      ] } }],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/driver/costs/spending?timeWindow=30D",
        "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }]
      }
    },
    {
      "name": "2. GET spending - vehicle filter (multi-vehicle)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
        "pm.test('Vehicle filter narrows results when data exists', function() {",
        "  const body = pm.response.json();",
        "  const expectedVehicleId = pm.collectionVariables.get('vehicle_id_2');",
        "  pm.expect(body.breakdownByVehicle).to.be.an('array');",
        "  pm.expect(body.breakdownByVehicle.length).to.be.at.most(1);",
        "  if (body.breakdownByVehicle.length === 1) {",
        "    pm.expect(body.breakdownByVehicle[0].vehicleId).to.eql(expectedVehicleId);",
        "  }",
        "  if (Array.isArray(body.history) && body.history.length > 0) {",
        "    const mismatches = body.history.filter(i => i.vehicleId && i.vehicleId !== expectedVehicleId);",
        "    pm.expect(mismatches.length).to.eql(0);",
        "  }",
        "});"
      ] } }],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/driver/costs/spending?timeWindow=30D&vehicleId={{vehicle_id_2}}",
        "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }]
      }
    },
    {
      "name": "3. GET spending - empty history in future range",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
        "pm.test('Empty arrays and zero totals', function() {",
        "  const body = pm.response.json();",
        "  pm.expect(body.totals.totalSpent).to.eql(0);",
        "  pm.expect(body.timeseries.length).to.eql(0);",
        "  pm.expect(body.history.length).to.eql(0);",
        "});"
      ] } }],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/driver/costs/spending?from=2030-01-01&to=2030-01-31",
        "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }]
      }
    },
    {
      "name": "4. GET spending - invalid range (400)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 400', function() { pm.response.to.have.status(400); });"
      ] } }],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/driver/costs/spending?from=2026-04-20&to=2026-04-01",
        "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }]
      }
    },
    {
      "name": "5. GET spending - unknown vehicleId (404)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 404', function() { pm.response.to.have.status(404); });"
      ] } }],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/driver/costs/spending?vehicleId=11111111-1111-1111-1111-111111111111",
        "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }]
      }
    },
    {
      "name": "6. GET spending - no token (401)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 401', function() { pm.response.to.have.status(401); });"
      ] } }],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/driver/costs/spending?timeWindow=7D"
      }
    },
    {
      "name": "7. GET spending - wrong role (403)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 403', function() { pm.response.to.have.status(403); });"
      ] } }],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/driver/costs/spending?timeWindow=7D",
        "header": [{ "key": "Authorization", "value": "Bearer {{manager_token}}" }]
      }
    }
  ]
}
