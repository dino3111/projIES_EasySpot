{
  "info": {
    "name": "EasySpot - Reports",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "driver_token", "value": "" },
    { "key": "manager_token", "value": "" },
    { "key": "technical_token", "value": "" },
    { "key": "unknown_driver_token", "value": "" },
    { "key": "park_id", "value": "" },
    { "key": "valid_image_path", "value": "postman/files/valid-image.svg" },
    { "key": "invalid_file_path", "value": "postman/files/not-image.txt" },
    { "key": "max_size_file_path", "value": "postman/files/max-size-10mb.bin" },
    { "key": "oversized_file_path", "value": "postman/files/oversized.bin" }
  ],
  "item": [
    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Get Driver JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Driver JWT obtained', function() {",
                  "  pm.response.to.have.status(200);",
                  "  const token = pm.response.json().access_token;",
                  "  pm.expect(token).to.be.a('string');",
                  "  pm.collectionVariables.set('driver_token', token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/test/token?role=DRIVER"
          }
        },
        {
          "name": "Get Manager JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Manager JWT obtained', function() {",
                  "  pm.response.to.have.status(200);",
                  "  const token = pm.response.json().access_token;",
                  "  pm.expect(token).to.be.a('string');",
                  "  pm.collectionVariables.set('manager_token', token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/test/token?role=MANAGER"
          }
        },
        {
          "name": "Get Technical JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Technical JWT obtained', function() {",
                  "  pm.response.to.have.status(200);",
                  "  const token = pm.response.json().access_token;",
                  "  pm.expect(token).to.be.a('string');",
                  "  pm.collectionVariables.set('technical_token', token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/test/token?role=TECHNICAL"
          }
        },
        {
          "name": "Get Unknown Driver JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unknown driver JWT obtained', function() {",
                  "  pm.response.to.have.status(200);",
                  "  const token = pm.response.json().access_token;",
                  "  pm.expect(token).to.be.a('string');",
                  "  pm.collectionVariables.set('unknown_driver_token', token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/test/token?role=DRIVER&sub=auth-sub-postman-ghost-driver"
          }
        },
        {
          "name": "Seed Test Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Seed data returned', function() {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.parkId).to.be.a('string');",
                  "  pm.collectionVariables.set('park_id', body.parkId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/test/seed",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }]
          }
        }
      ]
    },
    {
      "name": "1. Submit Report - Warning - Created (201)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 201', function() { pm.response.to.have.status(201); });",
        "pm.test('Response payload (warning) is correct', function() {",
        "  const body = pm.response.json();",
        "  pm.expect(body.id).to.be.a('string');",
        "  pm.expect(body.type).to.eql('CLIENT');",
        "  pm.expect(body.parkId).to.eql(pm.collectionVariables.get('park_id'));",
        "  pm.expect(body.zone).to.eql('A');",
        "  pm.expect(body.spotNumber).to.eql('12');",
        "  pm.expect(body.plate).to.eql('11-AA-11');",
        "  pm.expect(body.description).to.eql('Vehicle parked in a reserved spot.');",
        "  pm.expect(body.photoUrl).to.eql(null);",
        "  pm.expect(body.severity).to.eql('WARNING');",
        "  pm.expect(body.state).to.eql('OPEN');",
        "  pm.expect(body.createdAt).to.be.a('string');",
        "});"
      ] } }],
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/reports",
        "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "parkingLotId", "value": "{{park_id}}", "type": "text" },
            { "key": "zone", "value": "A", "type": "text" },
            { "key": "spotNumber", "value": "12", "type": "text" },
            { "key": "violationType", "value": "reserved", "type": "text" },
            { "key": "vehiclePlate", "value": "11-AA-11", "type": "text" },
            { "key": "description", "value": "Vehicle parked in a reserved spot.", "type": "text" }
          ]
        }
      }
    },
    {
      "name": "2. Submit Report - Critical + Photo - Created (201)",
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('Status 201', function() { pm.response.to.have.status(201); });",
        "pm.test('Response payload (critical) is correct', function() {",
        "  const body = pm.response.json();",
        "  pm.expect(body.id).to.be.a('string');",
        "  pm.expect(body.zone).to.eql('B');",
        "  pm.expect(body.spotNumber).to.eql('01');",
        "  pm.expect(body.plate).to.eql(null);",
        "  pm.expect(body.severity).to.eql('CRITICAL');",
        "  pm.expect(body.photoUrl).to.be.a('string');",
        "  pm.expect(body.photoUrl).to.include('/r2/reports/');",
        "});"
      ] } }],
      "request": {
        "method": "POST",
        "url": "{{base_url}}/api/reports",
        "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "parkingLotId", "value": "{{park_id}}", "type": "text" },
            { "key": "zone", "value": "B", "type": "text" },
            { "key": "spotNumber", "value": "01", "type": "text" },
            { "key": "violationType", "value": "blocking", "type": "text" },
            { "key": "description", "value": "Blocking another parked vehicle.", "type": "text" },
            { "key": "photo", "type": "file", "src": "{{valid_image_path}}" }
          ]
        }
      }
    },
