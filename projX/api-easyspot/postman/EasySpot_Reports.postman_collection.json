        "method": "POST",
        "url": "{{base_url}}/api/reports",
        "header": [
          { "key": "Authorization", "value": "Bearer {{driver_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"parkingLotId\": \"{{park_id}}\",\n  \"zone\": \"A\",\n  \"spotNumber\": \"27\",\n  \"violationType\": \"other\",\n  \"description\": \"JSON should be rejected because endpoint consumes multipart.\"\n}"
        }
      }
    }
  ]
