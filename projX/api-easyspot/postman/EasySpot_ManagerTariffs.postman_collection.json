{
	"info": {
		"_postman_id": "c1d2e3f4-5a6b-7c8d-9e0f-a1b2c3d4e5f6",
		"name": "EasySpot_ManagerTariffs",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "List All Tariffs",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{jwt}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/manager/tariffs",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"manager",
						"tariffs"
					]
				}
			},
			"response": []
		},
		{
			"name": "Filter Tariffs by City",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{jwt}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/manager/tariffs?city=Aveiro",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"manager",
						"tariffs"
					],
					"query": [
						{
							"key": "city",
							"value": "Aveiro"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "Update Tariff",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Tariff updated correctly\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.pricePerHour).to.eql(2.5);",
							"    pm.expect(jsonData.status).to.eql(\"ACTIVE\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{jwt}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"parkId\": \"{{park_id}}\",\n  \"pricePerHour\": 2.50,\n  \"maxDaily\": 20.00,\n  \"monthlyPrice\": 150.00,\n  \"pricePerKwh\": 0.35,\n  \"status\": \"ACTIVE\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/manager/tariffs",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"manager",
						"tariffs"
					]
				}
			},
			"response": []
		},
		{
			"name": "Unauthorized - Non-Manager Role",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 403\", function () {",
							"    pm.response.to.have.status(403);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{driver_jwt}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/manager/tariffs",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"manager",
						"tariffs"
					]
				}
			},
			"response": []
		}
	]
}
