# ============================================
# Authentik Configuration
# ============================================
# Generate secret with: openssl rand -hex 32
AUTHENTIK_SECRET_KEY=change-me-with-secret-from-github
AUTHENTIK_TAG=2024.12.3

# Authentik PostgreSQL credentials
PG_USER=authentik
PG_DB=authentik
PG_PASS=change-me-with-secret-from-github

# SonarQube Configuration
# SonarQube PostgreSQL password
SONAR_DB_PASSWORD=change-me-with-secret-from-github

# SonarQube GitHub OAuth (Authentik app credentials)
SONAR_GITHUB_CLIENT_ID=change-me-with-secret-from-github
SONAR_GITHUB_CLIENT_SECRET=change-me-with-secret-from-github

# Backend Application Database (PostgreSQL)
APP_DB_USER=easyspot
APP_DB_PASS=change-me-with-secret-from-github
APP_DB=easyspot

# Backend Time-Series Database (TimescaleDB)
TS_DB=easyspot_ts

# Kafka advertised host for external consumers
# Example target when the backend is reachable only through VPN:
# KAFKA_ADVERTISED_HOST=<vpn-host>
KAFKA_ADVERTISED_HOST=kafka

# Stripe CLI profile for local webhook forwarding
# API key is loaded from projX/.stripe_api_key (plain text key, one line)
# Example target when the backend is reachable only through VPN:
# STRIPE_WEBHOOK_FORWARD_TO=http://<vpn-host>:8080/api/billing/webhooks/stripe
STRIPE_WEBHOOK_FORWARD_TO=

# Stripe dashboard bootstrap (configured in GitHub secrets/vars)
# secrets: STRIPE_API_KEY, STRIPE_WEBHOOK_PUBLIC_URL, STRIPE_WEBHOOK_ENDPOINT_ID(optional)
# vars: STRIPE_WEBHOOK_EVENTS, STRIPE_WEBHOOK_DESCRIPTION,
#       STRIPE_REQUIRED_PAYMENT_METHODS, STRIPE_PAYMENT_METHOD_CHECK_STRICT

# API / Backend Configuration
AUTHENTIK_ISSUER_URI=http://authentik-server:9000/application/o/easyspot/
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost
FIREBASE_API_KEY=change-me
R2_ACCOUNT_ID=change-me
R2_ACCESS_KEY=change-me
R2_SECRET_KEY=change-me
R2_BUCKET=easyspot-media
R2_PUBLIC_URL=change-me

# Authentik Bootstrap Script
# Run: python3 bootstrap_authentik.py
# The script reads AUTHENTIK_BOOTSTRAP_TOKEN or falls back to AUTHENTIK_ADMIN_TOKEN
AUTHENTIK_BOOTSTRAP_TOKEN=change-me-generate-in-authentik-admin-ui
# Frontend OAuth2 callback URL (PKCE public client)
AUTHENTIK_REDIRECT_URI=http://localhost:5173/callback

# Docker Configuration
UID=1000
GID=1000
