# Authentik version
AUTHENTIK_TAG=2026.2.1

# Authentik secret key — generate with: openssl rand -hex 32
AUTHENTIK_SECRET_KEY=change-me

# Authentik PostgreSQL
PG_USER=authentik
PG_DB=authentik
PG_PASS=change-me
# Authentik
# Generate with: openssl rand -hex 32
AUTHENTIK_SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32
AUTHENTIK_TAG=2024.12.3

# Authentik PostgreSQL
PG_PASS=your_postgres_password
PG_USER=authentik
PG_DB=authentik

# SonarQube PostgreSQL
SONAR_DB_PASSWORD=your_sonarqube_db_password

# SonarQube GitHub OAuth
SONAR_GITHUB_CLIENT_ID=your_github_client_id
SONAR_GITHUB_CLIENT_SECRET=your_github_client_secret

# Docker User Mapping (prevents permission denied errors)
UID=1000
GID=1000
