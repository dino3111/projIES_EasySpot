              "var arrival = new Date(Date.now() + 2.5 * 60 * 60 * 1000).toISOString();",
              "var departure = new Date(Date.now() + 3.5 * 60 * 60 * 1000).toISOString();",
              "pm.collectionVariables.set('dblArrival', arrival);",
