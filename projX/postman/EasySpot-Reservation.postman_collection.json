{
  "info": {
    "name": "EasySpot - Reservation API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "reservationId",
      "value": ""
    },
    {
      "key": "bookingCode",
      "value": ""
    },
    {
      "key": "seedParkId",
      "value": ""
    },
    {
      "key": "seedVehicleId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Setup - Fetch seeded IDs",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Seed endpoint returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var body = pm.response.json();",
              "pm.test('seedParkId is present', function () {",
              "  pm.expect(body.parkId).to.be.a('string');",
              "});",
              "pm.test('seedVehicleId is present', function () {",
              "  pm.expect(body.vehicleId).to.be.a('string');",
              "});",
              "pm.collectionVariables.set('seedParkId', body.parkId);",
              "pm.collectionVariables.set('seedVehicleId', body.vehicleId);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{driverToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/test/seed",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "test",
            "seed"
          ]
        }
      }
    },
    {
      "name": "POST reservation - 201 success",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var arrival = new Date(Date.now() + 2 * 60 * 60 * 1000).toISOString();",
              "var departure = new Date(Date.now() + 4 * 60 * 60 * 1000).toISOString();",
              "pm.collectionVariables.set('arrivalDateTime', arrival);",
              "pm.collectionVariables.set('departureDateTime', departure);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var body = pm.response.json();",
              "pm.test('Has booking code starting with ES-', function () {",
              "  pm.expect(body.bookingCode).to.match(/^ES-/);",
              "});",
              "pm.test('Status is CONFIRMED', function () {",
              "  pm.expect(body.status).to.eql('CONFIRMED');",
              "});",
              "pm.test('Response has expected fields', function () {",
              "  pm.expect(body).to.have.property('reservationId');",
              "  pm.expect(body).to.have.property('parkId');",
              "  pm.expect(body).to.have.property('parkName');",
              "  pm.expect(body).to.have.property('vehicleId');",
              "  pm.expect(body).to.have.property('arrivalDateTime');",
              "  pm.expect(body).to.have.property('departureDateTime');",
              "  pm.expect(body).to.have.property('lockedUntil');",
              "  pm.expect(body).to.have.property('estimatedCost');",
              "});",
              "pm.collectionVariables.set('reservationId', body.reservationId);",
              "pm.collectionVariables.set('bookingCode', body.bookingCode);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{driverToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"parkId\":\"{{seedParkId}}\",\"vehicleId\":\"{{seedVehicleId}}\",\"arrivalDateTime\":\"{{arrivalDateTime}}\",\"departureDateTime\":\"{{departureDateTime}}\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/reservations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reservations"
          ]
        }
      }
    },
    {
      "name": "POST reservation - 201 idempotency first call",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var arrival = new Date(Date.now() + 6 * 60 * 60 * 1000).toISOString();",
              "var departure = new Date(Date.now() + 8 * 60 * 60 * 1000).toISOString();",
              "pm.collectionVariables.set('idemArrival', arrival);",
              "pm.collectionVariables.set('idemDeparture', departure);",
              "pm.collectionVariables.set('idemKey', 'idempotency-test-' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var body = pm.response.json();",
              "pm.collectionVariables.set('idemBookingCode', body.bookingCode);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{driverToken}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idemKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"parkId\":\"{{seedParkId}}\",\"vehicleId\":\"{{seedVehicleId}}\",\"arrivalDateTime\":\"{{idemArrival}}\",\"departureDateTime\":\"{{idemDeparture}}\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/reservations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reservations"
          ]
        }
      }
    },
    {
      "name": "POST reservation - 201 idempotency replay (same key)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var body = pm.response.json();",
              "pm.test('Same booking code as first call', function () {",
              "  pm.expect(body.bookingCode).to.eql(pm.collectionVariables.get('idemBookingCode'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{driverToken}}"
          },
          {
            "key": "Idempotency-Key",
