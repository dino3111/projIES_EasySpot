      "name": "PUT /api/manager/tariffs - 401 No Auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 401 when no token provided', function () {",
              "  pm.response.to.have.status(401);",
