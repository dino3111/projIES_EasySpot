{
  "info": {
    "name": "EasySpot - Manager Tariffs API",
    "description": "Comprehensive API tests for manager tariff management endpoints including GET listing and PUT updates with full edge case coverage",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "parkId", "value": "" },
    { "key": "managerToken", "value": "" }
  ],
  "item": [
    {
      "name": "Setup - Create Park (Prerequisite)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201 || pm.response.code === 200) {",
              "  var body = pm.response.json();",
              "  pm.environment.set('parkId', body.id);",
              "  pm.test('Park created successfully', function () {",
              "    pm.response.to.have.status([200, 201]);",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{managerToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Parking Lot\",\n  \"city\": \"Aveiro\",\n  \"address\": \"Rua de Teste 123\",\n  \"latitude\": 40.6412,\n  \"longitude\": -8.6536,\n  \"totalSpaces\": 100\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/parks" }
      }
    },
    {
      "name": "GET /api/manager/tariffs - 401 No Auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 401 when no token provided', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/manager/tariffs" }
      }
    },
    {
      "name": "GET /api/manager/tariffs - 403 Wrong Role",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 403 when user is not a manager', function () {",
              "  pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{driverToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/manager/tariffs" }
      }
    },
    {
      "name": "GET /api/manager/tariffs - 200 List All",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200 with tariff list', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is array', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.be.an('array');",
              "});",
              "pm.test('Each tariff has required fields', function () {",
              "  var body = pm.response.json();",
              "  if (body.length > 0) {",
              "    var tariff = body[0];",
              "    pm.expect(tariff).to.have.all.keys('id', 'parkId', 'parkName', 'city', 'pricePerHour', 'maxDaily', 'monthlyPrice', 'pricePerKwh', 'status');",
              "    pm.expect(tariff.id).to.be.a('string');",
              "    pm.expect(tariff.parkId).to.be.a('string');",
              "    pm.expect(tariff.parkName).to.be.a('string');",
              "    pm.expect(tariff.city).to.be.a('string');",
              "    pm.expect(tariff.status).to.be.oneOf(['ACTIVE', 'INACTIVE']);",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{managerToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/manager/tariffs" }
      }
    },
    {
      "name": "GET /api/manager/tariffs - Filter by City",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200 with filtered results', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('All results match the city filter', function () {",
              "  var body = pm.response.json();",
              "  if (body.length > 0) {",
              "    body.forEach(function(tariff) {",
              "      pm.expect(tariff.city.toLowerCase()).to.include('aveiro'.toLowerCase());",
              "    });",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{managerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/manager/tariffs?city=Aveiro",
          "query": [
            { "key": "city", "value": "Aveiro" }
          ]
        }
      }
    },
    {
      "name": "GET /api/manager/tariffs - Filter by Status ACTIVE",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200 with status-filtered results', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('All results have ACTIVE status', function () {",
              "  var body = pm.response.json();",
              "  body.forEach(function(tariff) {",
              "    pm.expect(tariff.status).to.equal('ACTIVE');",
              "  });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{managerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/manager/tariffs?status=ACTIVE",
          "query": [
            { "key": "status", "value": "ACTIVE" }
          ]
        }
      }
    },
    {
      "name": "GET /api/manager/tariffs - Filter by Status INACTIVE",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200 with status-filtered results', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('All results have INACTIVE status', function () {",
              "  var body = pm.response.json();",
              "  body.forEach(function(tariff) {",
              "    pm.expect(tariff.status).to.equal('INACTIVE');",
              "  });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{managerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/manager/tariffs?status=INACTIVE",
          "query": [
            { "key": "status", "value": "INACTIVE" }
          ]
        }
      }
    },
    {
      "name": "GET /api/manager/tariffs - Empty Result NonExistent City",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200 with empty array', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Result is empty array', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.be.an('array').that.is.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{managerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/manager/tariffs?city=NonExistentCity",
          "query": [
            { "key": "city", "value": "NonExistentCity" }
          ]
        }
      }
    },
