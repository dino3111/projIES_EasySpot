    {
      "name": "PUT /api/manager/tariffs - 200 Status Transition ACTIVE to INACTIVE",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200 with status transition', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Status changed to INACTIVE', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body.status).to.equal('INACTIVE');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{managerToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"parkId\": \"{{parkId}}\",\n  \"pricePerHour\": 1.50,\n  \"maxDaily\": 15.00,\n  \"monthlyPrice\": 100.00,\n  \"pricePerKwh\": 0.25,\n  \"status\": \"INACTIVE\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/manager/tariffs" }
      }
    },
    {
      "name": "GET /api/manager/tariffs - Verify Status Change",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Latest tariff shows INACTIVE status', function () {",
              "  var body = pm.response.json();",
              "  if (body.length > 0) {",
              "    var found = body.some(function(tariff) { return tariff.status === 'INACTIVE'; });",
              "    pm.expect(found).to.be.true;",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
