        },
        "url": { "raw": "{{baseUrl}}/api/manager/tariffs" }
      }
    },
    {
      "name": "PUT /api/manager/tariffs - 200 Success Update Tariff",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200 on successful update', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response contains updated tariff data', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property('id');",
              "  pm.expect(body).to.have.property('parkId');",
              "  pm.expect(body).to.have.property('pricePerHour').to.equal(2.5);",
              "  pm.expect(body).to.have.property('maxDaily').to.equal(20.0);",
              "  pm.expect(body).to.have.property('monthlyPrice').to.equal(150.0);",
              "  pm.expect(body).to.have.property('pricePerKwh').to.equal(0.35);",
              "  pm.expect(body).to.have.property('status').to.equal('ACTIVE');",
              "});",
              "pm.test('Audit trail created (implicit via response)', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{managerToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"parkId\": \"{{parkId}}\",\n  \"pricePerHour\": 2.50,\n  \"maxDaily\": 20.00,\n  \"monthlyPrice\": 150.00,\n  \"pricePerKwh\": 0.35,\n  \"status\": \"ACTIVE\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/manager/tariffs" }
