        "url": {
          "raw": "{{baseUrl}}/api/manager/tariffs?status=INACTIVE",
          "query": [
            { "key": "status", "value": "INACTIVE" }
          ]
        }
      }
    },
    {
      "name": "Contract Test - Tariff Response Schema",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Response matches TariffResponse schema', function () {",
              "  var body = pm.response.json();",
              "  if (Array.isArray(body) && body.length > 0) {",
              "    var tariff = body[0];",
              "    pm.expect(tariff).to.have.property('id').to.be.a('string');",
              "    pm.expect(tariff).to.have.property('parkId').to.be.a('string');",
              "    pm.expect(tariff).to.have.property('parkName').to.be.a('string');",
              "    pm.expect(tariff).to.have.property('city').to.be.a('string');",
              "    pm.expect(tariff).to.have.property('pricePerHour').to.be.a('number');",
              "    pm.expect(tariff).to.have.property('maxDaily').to.be.a('number');",
              "    pm.expect(tariff).to.have.property('monthlyPrice').to.be.a('number');",
              "    pm.expect(tariff).to.have.property('pricePerKwh').to.be.a('number');",
              "    pm.expect(tariff).to.have.property('status').to.be.oneOf(['ACTIVE', 'INACTIVE']);",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{managerToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/manager/tariffs" }
      }
