    {
      "name": "PUT /api/manager/tariffs - 200 Zero Prices Allowed",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200 with zero prices', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Zero prices accepted and stored', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body.pricePerHour).to.equal(0.0);",
              "  pm.expect(body.maxDaily).to.equal(0.0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{managerToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"parkId\": \"{{parkId}}\",\n  \"pricePerHour\": 0.00,\n  \"maxDaily\": 0.00,\n  \"monthlyPrice\": 0.00,\n  \"pricePerKwh\": 0.00,\n  \"status\": \"INACTIVE\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/manager/tariffs" }
      }
