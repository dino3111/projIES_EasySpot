            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/driver/costs/planning?city=Aveiro&estimatedDurationMinutes=60&lat=40.6405&lng=-8.6538&maxDistanceMeters=200",
              "host": ["{{baseUrl}}"],
