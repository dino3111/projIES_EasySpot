        {
          "name": "200 - maxDistanceMeters boundary - tight radius",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
            "var recs = pm.response.json().recommendations;",
            "pm.test('All results within max distance', function () {",
            "  recs.forEach(function (r) {",
            "    pm.expect(r.distanceMeters).to.be.at.most(200);",
