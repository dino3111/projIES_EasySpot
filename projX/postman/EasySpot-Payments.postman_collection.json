{
  "info": {
    "name": "EasySpot - Payments API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "paymentMethodId", "value": "" }
  ],
  "item": [
    {
      "name": "GET /payments/setup-status - 401 unauthenticated",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 401', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/payments/setup-status" }
      }
    },
    {
      "name": "GET /payments/setup-status - 200 authenticated",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has configured field', function () {",
              "  pm.expect(pm.response.json()).to.have.property('configured');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{driverToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/payments/setup-status" }
      }
    },
    {
      "name": "GET /payments/methods - 401 unauthenticated",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 401', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/payments/methods" }
      }
    },
    {
      "name": "GET /payments/methods - 200 list payment methods",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is an array', function () {",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});",
              "var body = pm.response.json();",
              "if (body.length > 0) {",
              "  pm.collectionVariables.set('paymentMethodId', body[0].id);",
              "  pm.test('Payment method has required fields', function () {",
              "    pm.expect(body[0]).to.have.property('id');",
              "    pm.expect(body[0]).to.have.property('brand');",
              "    pm.expect(body[0]).to.have.property('last4');",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{driverToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/payments/methods" }
      }
    },
    {
      "name": "DELETE /payments/methods/{id} - 401 unauthenticated",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 401', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/payments/methods/pm_test_123" }
      }
    },
    {
      "name": "DELETE /payments/methods/{id} - 204 detach method",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 204', function () {",
              "  pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{driverToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/payments/methods/{{paymentMethodId}}" }
      }
    },
    {
      "name": "POST /payments/setup-intent - 200 authenticated",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is a client secret string', function () {",
              "  pm.expect(pm.response.text()).to.be.a('string');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{driverToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/payments/setup-intent" }
      }
    },
    {
      "name": "GET /payments/status - 200 authenticated",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has status field', function () {",
              "  pm.expect(pm.response.json()).to.have.property('status');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{driverToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/payments/status?reservationId={{reservationId}}",
          "query": [{ "key": "reservationId", "value": "{{reservationId}}" }]
        }
      }
    }
  ]
}
