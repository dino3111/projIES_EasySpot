
// Auth and Users

Table users {
  id UUID [pk]
  authentik_user_id VARCHAR [unique, not null]
  authentik_pk VARCHAR
  email VARCHAR [unique, not null]
  name VARCHAR [not null]
  photo_url VARCHAR
  role VARCHAR [not null, note: 'DRIVER | MANAGER | TECHNICIAN']
  stripe_customer_id VARCHAR
  is_regular_driver BOOLEAN [not null, default: true]
  is_ev_driver BOOLEAN [not null, default: false]
  is_accessible_driver BOOLEAN [not null, default: false]
  notifications_enabled BOOLEAN [not null, default: true]
  push_notifications_enabled BOOLEAN [not null, default: true]
  email_notifications_enabled BOOLEAN [not null, default: false]
  created_at TIMESTAMP [default: `NOW()`]
  updated_at TIMESTAMP [default: `CURRENT_TIMESTAMP`]
}


Table user_authentik_sync {
  id UUID [pk]
  user_id UUID [unique, not null, ref: > users.id]
  authentik_user_id VARCHAR [unique, not null]
  authentik_email VARCHAR [not null, default: '']
  authentik_groups JSONB [not null, default: '[]', note: '["DRIVER","MANAGER"] from Authentik']
  synced_at TIMESTAMP [default: `NOW()`]
  updated_at TIMESTAMP [default: `CURRENT_TIMESTAMP`]
}

// Vehicles

Table vehicles {
  id UUID [pk]
  user_id UUID [not null, ref: > users.id]
  plate VARCHAR [unique, not null]
  vin VARCHAR [unique]
  make VARCHAR [not null]
  model VARCHAR [not null]
  version VARCHAR
  color VARCHAR
  year INT [not null]
  year_to INT
  fuel_type VARCHAR [not null]
  power_kw DECIMAL(5,2)
  power_cv DECIMAL(5,2)
  displacement_cc INT
  cylinders INT
  body_type VARCHAR
  drive_type VARCHAR
  engine_code VARCHAR
  engine_type VARCHAR
  image_url VARCHAR
  brand_logo_url VARCHAR
  external_source_id VARCHAR
  nickname VARCHAR
  is_ev BOOLEAN [not null, default: false]
  is_primary BOOLEAN [not null, default: false]
  charger_types_json TEXT [note: 'JSON array e.g. ["Type2","CCS"]']
  last_synced_at TIMESTAMP
  synced_data_json TEXT
  created_at TIMESTAMP [default: `NOW()`]
  updated_at TIMESTAMP [default: `CURRENT_TIMESTAMP`]
}

// Parking Infrastructure

Table parking_lots {
  id UUID [pk]
  name VARCHAR [not null]
  city VARCHAR [not null]
  address VARCHAR [not null]
  latitude DECIMAL(9,6) [not null]
  longitude DECIMAL(9,6) [not null]
  opening_hours VARCHAR
  total_spaces INT [not null]
  technician_user_id UUID [ref: > users.id]
  created_at TIMESTAMP [default: `NOW()`]
  updated_at TIMESTAMP [default: `CURRENT_TIMESTAMP`]
}

Table parking_lot_amenities {
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  amenity VARCHAR [not null]
}

Table parking_spots {
  id UUID [pk]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  spot_number VARCHAR [not null]
  zone VARCHAR [not null, note: 'STANDARD | EV | ACCESSIBLE | RESERVED']
  spot_row INT [not null]
  spot_col INT [not null]
  status VARCHAR [not null, note: 'free | occupied | reserved | ev | accessible']
}

Table ev_chargers {
  id UUID [pk]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  type VARCHAR [not null]
  speed VARCHAR [not null]
  price_per_kwh DECIMAL(10,2)
  available BOOLEAN [not null]
}

Table accessible_spots {
  id UUID [pk]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  location VARCHAR [not null]
  available BOOLEAN [not null]
  distance_to_entrance_meters INT [not null]
  bay_size VARCHAR
  monitored BOOLEAN [not null, default: false]
  has_ramp_space BOOLEAN [not null, default: false]
  sensor_status VARCHAR [default: 'online']
  led_status VARCHAR [default: 'green']
}

Table technician_park_assignments {
  id UUID [pk]
  technician_id UUID [not null, ref: > users.id]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  assigned_at TIMESTAMP [default: `NOW()`]
}

// Sensors

Table sensor_registry {
  sensor_id VARCHAR [pk]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  zone VARCHAR
  status VARCHAR [not null, note: 'OPERATIONAL | DEGRADED | OFFLINE | MAINTENANCE']
  last_seen_at TIMESTAMP [not null]
  created_at TIMESTAMP [not null]
}

// Tariffs

Table tariffs {
  id UUID [pk]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  name VARCHAR [not null]
  description VARCHAR
  price_per_hour DECIMAL(10,2)
  max_daily DECIMAL(10,2)
  monthly DECIMAL(10,2)
  price_per_kwh DECIMAL(10,2)
  status VARCHAR [not null, default: 'ACTIVE', note: 'ACTIVE | INACTIVE']
}

Table tariff_audit {
  id UUID [pk]
  tariff_id UUID [not null, ref: > tariffs.id]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  price_per_hour DECIMAL(10,2)
  max_daily DECIMAL(10,2)
  monthly DECIMAL(10,2)
  price_per_kwh DECIMAL(10,2)
  status VARCHAR [note: 'ACTIVE | INACTIVE']
  changed_at TIMESTAMP [not null, default: `NOW()`]
  changed_by VARCHAR [not null]
}

// Bookings

Table reservations {
  id UUID [pk]
  user_id UUID [not null, ref: > users.id]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  parking_spot_id UUID [ref: > parking_spots.id]
  vehicle_id UUID [ref: > vehicles.id]
  arrival_time TIMESTAMP [not null]
  departure_time TIMESTAMP [not null]
  status VARCHAR [not null, note: 'PENDING | CONFIRMED | CANCELLED | EXPIRED | COMPLETED']
  locked_until TIMESTAMP
  estimated_cost DECIMAL(10,2)
  booking_code VARCHAR [unique, not null]
  idempotency_key VARCHAR
  created_at TIMESTAMP [default: `NOW()`]
  updated_at TIMESTAMP [default: `CURRENT_TIMESTAMP`]

  indexes {
    (user_id, idempotency_key) [unique]
  }
}

Table user_favorites {
  id UUID [pk]
  user_id UUID [not null, ref: > users.id]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  created_at TIMESTAMP [default: `NOW()`]

  indexes {
    (user_id, parking_lot_id) [unique]
  }
}

// Billing

Table payment_records {
  id UUID [pk]
  reservation_id UUID [not null, ref: > reservations.id]
  user_id UUID [not null, ref: > users.id]
  stripe_session_id VARCHAR [unique]
  payment_intent_id VARCHAR [unique]
  amount DECIMAL(10,2) [not null]
  currency VARCHAR(3) [not null]
  status VARCHAR [not null, note: 'PENDING | COMPLETED | FAILED | REFUNDED | PARTIALLY_REFUNDED']
  customer_email VARCHAR
  created_at TIMESTAMP [default: `NOW()`]
  updated_at TIMESTAMP [default: `CURRENT_TIMESTAMP`]
}

Table processed_stripe_events {
  event_id VARCHAR [pk]
  processed_at TIMESTAMP [default: `NOW()`]
}

// OCR

Table ocr_plate_reads {
  id UUID [pk]
  park_id UUID [not null, ref: > parking_lots.id]
  spot_id UUID [ref: > parking_spots.id]
  plate VARCHAR [not null]
  confidence DECIMAL(5,4) [not null]
  direction VARCHAR [not null, note: 'entry | exit']
  failure_mode VARCHAR
  occurred_at TIMESTAMP [not null]
  extra JSONB
}

// Notifications

Table alert_subscriptions {
  id UUID [pk]
  user_id UUID [not null, ref: > users.id]
  alert_type VARCHAR [not null, note: 'LOT_FULL | SPACE_AVAILABLE | EV_CHARGER_AVAILABLE | SENSOR_FAULT | DAILY_SUMMARY']
  park_ids_csv VARCHAR
  park_scope_key VARCHAR [not null]
  vehicle_id VARCHAR
  email VARCHAR [not null]
  schedule_frequency VARCHAR [note: 'DAILY | WEEKLY']
  schedule_time VARCHAR
  schedule_timezone VARCHAR
  enabled BOOLEAN [not null, default: true]
  created_at TIMESTAMP [default: `NOW()`]

  indexes {
    (user_id, alert_type, park_scope_key) [unique]
  }
}

Table notification_email_deliveries {
  id UUID [pk]
  delivery_key VARCHAR [unique, not null]
  user_id UUID [ref: > users.id]
  category VARCHAR [not null]
  recipient VARCHAR [not null]
  subject VARCHAR [not null]
  status VARCHAR [not null, note: 'PENDING | SENT | FAILED']
  error_message VARCHAR
  sent_at TIMESTAMP
  created_at TIMESTAMP [default: `NOW()`]
  updated_at TIMESTAMP [default: `CURRENT_TIMESTAMP`]
}

// Parking Sessions and Occupancy (TimescaleDB hypertables)

Table parking_sessions {
  id UUID [pk]
  reservation_id UUID [ref: > reservations.id]
  user_id UUID [ref: > users.id]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  vehicle_id UUID [ref: > vehicles.id]
  zone_type TEXT [not null, note: 'STANDARD | EV | ACCESSIBLE | RESERVED']
  entry_time TIMESTAMPTZ [not null, note: 'TimescaleDB partitioning key']
  exit_time TIMESTAMPTZ [not null]
  revenue_euros NUMERIC(8,2)
}

Table occupancy_snapshots {
  id UUID [pk]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  zone_type TEXT [not null, note: 'STANDARD | EV | ACCESSIBLE | RESERVED']
  occupied_count INT [not null]
  total_count INT [not null]
  recorded_at TIMESTAMPTZ [not null, note: 'TimescaleDB partitioning key']
}

Table alert_state_history {
  id UUID [pk]
  alert_id UUID [not null, ref: > alerts.id]
  previous_state TEXT
  new_state TEXT [not null]
  changed_by TEXT
  notes TEXT
  changed_at TIMESTAMPTZ [not null, note: 'TimescaleDB partitioning key']
}

Table backend_decision_history {
  id UUID [pk]
  entity_type TEXT [not null]
  entity_id TEXT [not null]
  decision_type TEXT [not null]
  decision_source TEXT [not null]
  details TEXT
  decided_at TIMESTAMPTZ [not null, note: 'TimescaleDB partitioning key']
}

// Alerts and Reports (TimescaleDB hypertable)

Table alerts {
  id UUID [pk]
  parking_lot_id UUID [not null, ref: > parking_lots.id]
  parking_lot_name VARCHAR
  type VARCHAR [not null, note: 'SENSOR | CLIENT | SYSTEM']
  severity VARCHAR [not null, note: 'CRITICAL | WARNING | INFO']
  state VARCHAR [not null, note: 'OPEN | IN_PROGRESS | RESOLVED']
  zone VARCHAR
  spot_number VARCHAR
  sensor_id VARCHAR [ref: > sensor_registry.sensor_id]
  plate VARCHAR
  description VARCHAR
  photo_url VARCHAR
  reported_by VARCHAR
  attributed_to VARCHAR
  notes VARCHAR
  resolved_at TIMESTAMP
  created_at TIMESTAMP [not null, note: 'TimescaleDB partitioning key']
}
